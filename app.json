{
  "expo": {
    "name": "Turcanime",
    "slug": "turcanime",
    "version": "1.10.11",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "turcanime",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "backgroundColor": "#000000",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "com.turcanime.app",
      "softwareKeyboardLayoutMode": "pan",
      "versionCode": 11011
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": [
              "arm64-v8a"
            ]
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "66c6dcc9-913f-4f33-941e-fde005fef2e7"
      }
    },
    "owner": "turcaman"
  }
}
